# Public Supabase settings used by the browser app.
# Set these in Vercel Project Settings > Environment Variables.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only keys must never be exposed to the browser.
# Add this only when server-side admin operations are implemented.
SUPABASE_SERVICE_ROLE_KEY=

# Simple PIN for the headquarters maintenance page at /admin.
ADMIN_MAINTENANCE_PIN=
